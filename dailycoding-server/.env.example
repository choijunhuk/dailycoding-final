PORT=4000
JWT_SECRET=your_jwt_secret_here

# 단일 VPS 도메인 기준 CORS
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
AUTH_COOKIE_SAMESITE=Lax
# 프론트와 API가 서로 다른 사이트인 경우에만 None으로 바꾸고 HTTPS에서 운영하세요.
# AUTH_COOKIE_SAMESITE=None
# AUTH_COOKIE_DOMAIN=.yourdomain.com

# 관리자 초기 비밀번호 (최초 계정 생성 시에만 사용)
ADMIN_PASSWORD=your_admin_password

# 로컬 검증용 부트스트랩 (개발 전용, production에서는 무시됨)
ENABLE_LOCAL_BOOTSTRAP=false
LOCAL_ADMIN_PASSWORD=local-admin-1234
LOCAL_TEST_EMAIL=tester@dailycoding.local
LOCAL_TEST_USERNAME=LocalTester
LOCAL_TEST_PASSWORD=local-tester-1234
LOCAL_TEST_RATING=800

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key

# MySQL (Docker Compose 컨테이너를 같은 호스트에서 사용)
MYSQL_ROOT_PASSWORD=your_mysql_root_password
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=dailycoding
DB_USER=your_db_user
DB_PASS=your_db_password

# Redis
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@127.0.0.1:6379

# Judge mode
JUDGE_MODE=docker

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=https://yourdomain.com/api/auth/github/callback

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# Frontend URL
FRONTEND_URL=https://yourdomain.com

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=DailyCoding <noreply@yourdomain.com>

# Stripe Price IDs / Payment Links
STRIPE_PRO_MONTHLY_ID=price_1TMw1HCLaoSRWv0iBNyj2VCG
STRIPE_PRO_ANNUAL_ID=price_1TMw5LCLaoSRWv0iZLncCZez
STRIPE_TEAM_MONTHLY_ID=price_1TMw5hCLaoSRWv0i1qtbccfV
STRIPE_TEAM_ANNUAL_ID=price_1TMw66CLaoSRWv0iPJLPw5Pu
STRIPE_PRO_MONTHLY_URL=https://buy.stripe.com/your_pro_monthly_link
STRIPE_PRO_ANNUAL_URL=https://buy.stripe.com/your_pro_annual_link
STRIPE_TEAM_MONTHLY_URL=https://buy.stripe.com/your_team_monthly_link
STRIPE_TEAM_ANNUAL_URL=https://buy.stripe.com/your_team_annual_link
