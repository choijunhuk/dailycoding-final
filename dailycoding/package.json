{
  "name": "dailycoding",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "start": "npx serve -s dist -l ${PORT:-3000}",
    "lint": "npx eslint src --ext .js,.jsx --max-warnings 0",
    "lint:fix": "npx eslint src --ext .js,.jsx --fix",
    "verify": "npm run lint && npm test && npm run build",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "axios": "^1.6.0",
    "canvas-confetti": "^1.9.4",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.0",
    "serve": "^14.2.6",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.6",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.1.1",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "dompurify": "^3.4.0"
  }
}
