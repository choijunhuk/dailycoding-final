{
  "env": { "browser": true, "es2022": true },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "plugins": ["react"],
  "extends": ["eslint:recommended"],
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "react/jsx-uses-vars": "error",
    "react/jsx-uses-react": "error"
  }
}
